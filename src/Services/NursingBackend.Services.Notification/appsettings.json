{
  "ConnectionStrings": {
    "Postgres": "Host=localhost;Port=5432;Database=nursing_notification;Username=nursing;Password=nursing"
  },
  "Jwt": {
    "Issuer": "nursing-platform",
    "Audience": "nursing-platform-clients",
    "SigningKey": "nursing-platform-development-signing-key-2026",
    "ExpiresInMinutes": 480
  },
  "ServiceEndpoints": {
    "Billing": "http://localhost:5253"
  },
  "ProviderCallbacks": {
    "SharedKey": "development-provider-webhook-key",
    "AllowSharedKeyFallback": true,
    "SharedKeyHeaderName": "X-Provider-Webhook-Key",
    "DefaultProfile": {
      "Provider": "default",
      "SignatureMode": "HmacSha256",
      "SignatureEncoding": "HexLower",
      "SignaturePayloadMode": "TimestampDotBody",
      "SignatureHeaderName": "X-Provider-Signature",
      "TimestampHeaderName": "X-Provider-Timestamp",
      "TimestampToleranceSeconds": 300,
      "SignatureSecret": "development-provider-signature-secret"
    },
    "Profiles": [
      {
        "Provider": "twilio",
        "SignatureMode": "HmacSha256",
        "SignatureEncoding": "HexLower",
        "SignaturePayloadMode": "TimestampDotBody",
        "SignatureHeaderName": "X-Twilio-Signature",
        "TimestampHeaderName": "X-Twilio-Timestamp",
        "TimestampToleranceSeconds": 300,
        "SignatureSecret": "replace-twilio-signature-secret",
        "ChannelOverride": "sms",
        "StatusMappings": {
          "queued": "Queued",
          "delivered": "Delivered",
          "failed": "Failed",
          "undelivered": "Failed"
        }
      },
      {
        "Provider": "email-hmac-base64",
        "SignatureMode": "HmacSha256",
        "SignatureEncoding": "Base64",
        "SignaturePayloadMode": "Body",
        "SignaturePrefix": "sha256=",
        "SignatureHeaderName": "X-Provider-Signature",
        "TimestampHeaderName": "X-Provider-Timestamp",
        "TimestampToleranceSeconds": 0,
        "SignatureSecret": "replace-email-provider-signature-secret",
        "ChannelOverride": "email",
        "StatusMappings": {
          "accepted": "Queued",
          "processed": "Delivered",
          "dropped": "Failed",
          "bounced": "Failed"
        }
      }
    ]
  },
  "InternalServiceAuth": {
    "ApiKey": "development-internal-service-key"
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*"
}
