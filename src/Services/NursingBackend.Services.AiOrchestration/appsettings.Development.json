        "Provider": "mock",
        "Model": "mock-v1",
        "Temperature": 0.0,
        "MaxTokens": 512
      },
      "chat": {
        "Provider": "mock",
        "Model": "mock-v1",
        "Temperature": 0.0,
        "MaxTokens": 512
      },
      "generator": {
        "Provider": "mock",
        "Model": "mock-v1",
